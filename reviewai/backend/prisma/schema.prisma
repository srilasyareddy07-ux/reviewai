// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  firebaseUid   String    @unique
  email         String    @unique
  displayName   String?
  photoURL      String?
  githubToken   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviews       Review[]
  chats         Chat[]
  settings      Settings?
}

model Review {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  prUrl           String?
  repoName        String?
  prNumber        Int?
  prTitle         String?
  codeSnippet     String?
  language        String    @default("javascript")
  issues          Issue[]
  mergeScore      Float?
  qualityScore    Float?
  securityScore   Float?
  summary         String?
  rawDiff         String?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  chats           Chat[]
}

model Issue {
  id            String    @id @default(uuid())
  reviewId      String
  review        Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  title         String
  description   String
  severity      String    // critical, high, medium, low, info
  category      String    // security, performance, bug, smell, style
  lineNumber    Int?
  originalCode  String?
  fixedCode     String?
  confidence    Float?
  createdAt     DateTime  @default(now())
}

model Chat {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  reviewId  String?
  review    Review?   @relation(fields: [reviewId], references: [id])
  role      String    // user, assistant
  content   String
  createdAt DateTime  @default(now())
}

model Settings {
  id                    String    @id @default(uuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])
  darkMode              Boolean   @default(true)
  emailNotifications    Boolean   @default(true)
  autoAnalyze           Boolean   @default(false)
  githubWebhook         Boolean   @default(false)
  defaultLanguage       String    @default("javascript")
  groqApiKey            String?
  githubToken           String?
  updatedAt             DateTime  @updatedAt
}
